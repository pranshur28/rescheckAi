# Vertex AI RAG (server-side)
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1
RAG_CORPUS_ID=
# Inline service account JSON as a single-line string. Netlify Functions cannot
# read GOOGLE_APPLICATION_CREDENTIALS file paths, so we load JSON at cold start.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Gemini (server-side, separate auth from Vertex)
GEMINI_API_KEY=

# Cloudinary (frontend Upload Widget)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Server-side, only required if signed uploads are enabled (stretch goal)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Netlify
# NETLIFY_FUNCTIONS_REGION=us-east-1
# When "1", deployed URL renders demo presets without ?demo=1
DEMO_MODE_DEFAULT=
